{
  "name": "@diagrampilot/workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Repo-native diagram compiler for AI coding agents.",
  "type": "module",
  "license": "UNLICENSED",
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b && node packages/cli/scripts/make-bin-executable.mjs",
    "clean": "tsc -b --clean",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
