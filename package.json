{
  "name": "@diagrampilot/workspace",
  "version": "0.4.0",
  "private": true,
  "description": "Repo-native diagram compiler for AI coding agents.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StiensWout/DiagramPilot.git"
  },
  "homepage": "https://diagrampilot.com",
  "bugs": {
    "url": "https://github.com/StiensWout/DiagramPilot/issues"
  },
  "keywords": [
    "diagrampilot",
    "diagramspec",
    "diagram",
    "architecture",
    "agents",
    "software-architecture",
    "codebase-diagrams",
    "dependency-diagrams",
    "diagram-as-code",
    "architecture-as-code",
    "ai-agents",
    "git",
    "ci"
  ],
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*",
    "website"
  ],
  "scripts": {
    "build": "tsc -b && node packages/cli/scripts/make-bin-executable.mjs && node packages/mcp/scripts/make-bin-executable.mjs",
    "build:website": "npm --workspace website run build",
    "benchmark": "npm run build && node scripts/benchmark-workflows.mjs",
    "audit:maintainability": "npm run build && node scripts/audit-maintainability-file-sizes.mjs",
    "audit:fallow": "npm run build && npm run audit:fallow:dead-code && npm run audit:fallow:dupes && npm run audit:fallow:health",
    "audit:fallow:dead-code": "fallow dead-code --format compact --quiet --baseline fallow-baselines/dead-code.json --fail-on-issues",
    "audit:fallow:dupes": "fallow dupes --format compact --quiet --fail-on-issues",
    "audit:fallow:health": "fallow health --format compact --quiet --complexity --min-severity moderate",
    "audit:fallow:changed": "fallow audit --format compact --quiet --fail-on-issues --dead-code-baseline fallow-baselines/dead-code.json",
    "check:release-version": "node scripts/check-release-version.mjs",
    "clean": "tsc -b --clean",
    "generate:schema": "npm run build && node scripts/generate-diagramspec-v1-schema.mjs",
    "check:package-readiness": "node scripts/check-package-readiness.mjs",
    "check:package-size-budgets": "node scripts/check-package-size-budgets.mjs",
    "check:package-publish-state": "node scripts/check-package-publish-state.mjs",
    "release:bump": "node scripts/bump-release-version.mjs",
    "test": "npm run build && node --test --test-concurrency=1 test/*.test.mjs"
  },
  "devDependencies": {
    "@diagrampilot/core": "0.4.0",
    "@diagrampilot/render-svg": "0.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^25.9.1",
    "fallow": "^2.89.0",
    "typescript": "^6.0.3"
  }
}
