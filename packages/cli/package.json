{
  "name": "diagrampilot",
  "version": "0.1.7",
  "description": "DiagramPilot command line interface.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StiensWout/DiagramPilot.git",
    "directory": "packages/cli"
  },
  "homepage": "https://diagrampilot.com",
  "bugs": {
    "url": "https://github.com/StiensWout/DiagramPilot/issues"
  },
  "keywords": [
    "diagrampilot",
    "diagramspec",
    "diagram",
    "architecture",
    "cli"
  ],
  "bin": {
    "diagrampilot": "dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b && node scripts/make-bin-executable.mjs"
  },
  "dependencies": {
    "@diagrampilot/core": "0.1.7",
    "@diagrampilot/export-d2": "0.1.7",
    "@diagrampilot/export-mermaid": "0.1.7",
    "@diagrampilot/render-svg": "0.1.7"
  }
}
