{
  "name": "@diagrampilot/mcp",
  "version": "0.4.1",
  "description": "Model Context Protocol server for DiagramPilot.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StiensWout/DiagramPilot.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://diagrampilot.com",
  "bugs": {
