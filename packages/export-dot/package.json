{
  "name": "@diagrampilot/export-dot",
  "version": "0.2.9",
  "description": "DOT export adapter for DiagramPilot.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StiensWout/DiagramPilot.git",
    "directory": "packages/export-dot"
  },
  "homepage": "https://diagrampilot.com",
  "bugs": {
    "url": "https://github.com/StiensWout/DiagramPilot/issues"
  },
  "keywords": [
    "diagrampilot",
    "diagramspec",
    "diagram",
    "architecture",
    "dot",
    "graphviz"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
