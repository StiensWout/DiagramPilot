---
import LocalRepositoryPath from "../components/LocalRepositoryPath.astro";
import WorkflowDemo from "../components/WorkflowDemo.astro";
import "../styles/landing.css";
import "../styles/landing-workflow.css";
import "../styles/landing-local-path.css";
import "../styles/landing-mobile.css";

const quickCommand = "npx diagrampilot check";

const proofPoints = [
  {
    title: "Bring your own repository.",
    text: "DiagramPilot works where agents already work: in a checkout, next to source code, with artifacts a maintainer can review.",
  },
  {
    title: "One command before review.",
    text: "`diagrampilot check` discovers DiagramPilot source files, validates them, and reports stale same-stem SVG artifacts without rewriting the working tree.",
  },
  {
    title: "If it breaks, it says where.",
    text: "Repairable errors name the broken field so an AI coding agent can update the DiagramSpec file, validate again, and commit the repaired source plus rendered output.",
  },
  {
    title: "Author with local tools.",
    text: "`diagrampilot create`, `diagrampilot inspect`, `diagrampilot format`, and `diagrampilot watch` cover starter sources, read-only inventory, canonical YAML, and checked generation loops.",
  },
  {
    title: "MCP agent integration.",
    text: "Run `diagrampilot mcp` to expose read-only schema, docs, examples, validation, check, export, render, and prompt helpers to local MCP clients.",
  },
];

const structuredData = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "DiagramPilot",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "macOS, Linux, Windows",
  url: "https://diagrampilot.com/",
  codeRepository: "https://github.com/StiensWout/DiagramPilot",
  description:
    "Repo-native diagram compiler for AI coding agents that turns DiagramPilot Source Files into review-stable SVG artifacts.",
  featureList: [
    "Validate .dp.yaml DiagramPilot Source Files locally",
    "Generate review-stable SVG artifacts",
    "Use fixed Output Profiles for configured artifacts",
    "Install public npm packages for the CLI, core, MCP, exporters, and SVG renderer",
    "Expose agent-ready MCP helpers",
    "Keep diagram source and rendered output in the repository",
  ],
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>DiagramPilot | Repo-Native Diagrams For AI Coding Agents</title>
    <meta
      name="description"
      content="DiagramPilot turns .dp.yaml source files into review-stable SVG artifacts with local validation for AI coding agents and software repository reviews."
    />
    <meta
      name="keywords"
      content="DiagramPilot, repo-native diagrams, AI coding agents, DiagramSpec, diagram compiler, SVG artifacts, developer tools"
    />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="DiagramPilot" />
    <meta name="theme-color" content="#0f172a" />
    <link rel="canonical" href="https://diagrampilot.com/" />
    <link rel="icon" href="/brand/diagrampilot-mark.svg" type="image/svg+xml" />
    <meta
      property="og:title"
      content="DiagramPilot | Repo-Native Diagram Compiler"
    />
    <meta
      property="og:description"
      content="Validate .dp.yaml diagram source, generate review-stable SVG artifacts, and keep AI agent diagram changes inside the repository."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://diagrampilot.com/" />
    <meta property="og:site_name" content="DiagramPilot" />
    <meta property="og:locale" content="en_US" />
    <meta
      property="og:image"
      content="https://diagrampilot.com/landing/hero-workflow.png"
    />
    <meta
      property="og:image:alt"
      content="DiagramPilot repository workflow showing source, validation, and SVG output."
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="DiagramPilot | Repo-Native Diagram Compiler"
    />
    <meta
      name="twitter:description"
      content="A local developer workflow for .dp.yaml source, repository checks, generated SVG artifacts, and AI coding agents."
    />
    <meta
      name="twitter:image"
      content="https://diagrampilot.com/landing/hero-workflow.png"
    />
    <meta
      name="twitter:image:alt"
      content="DiagramPilot repository workflow showing source, validation, and SVG output."
    />
    <script type="application/ld+json" set:html={structuredData}></script>
  </head>
  <body class="landing-page">
    <a class="skip-link" href="#main">Skip to content</a>

    <main id="main">
      <section class="hero-zone" aria-labelledby="landing-title">
        <div class="hero-copy motion-rise">
          <p class="hero-eyebrow">Repo-native diagram compiler for AI coding agents</p>
          <h1 id="landing-title" class="sr-only">DiagramPilot</h1>
          <img
            class="hero-wordmark"
            src="/brand/diagrampilot-logo-light.svg"
            alt=""
            width="720"
            height="160"
            decoding="async"
          />
          <p class="promise">
            Commit diagrams like code: `.dp.yaml` source in the repo, local
            checks before review, and SVG artifacts maintainers can inspect.
          </p>
          <div class="hero-actions" aria-label="Primary actions">
            <a class="action action-primary" href="#workflow-proof">
              See the workflow
            </a>
            <a class="action action-secondary" href="/docs/agents/installation/">
              Install Guide
            </a>
            <a
              class="action action-secondary"
              href="/docs/"
            >
              Read Docs
            </a>
          </div>
          <div class="quick-command" aria-label="Quick command">
            <code>{quickCommand}</code>
            <button
              type="button"
              class="command-copy"
              data-copy-command={quickCommand}
              aria-label="Copy npx diagrampilot check"
            >
              Copy
            </button>
          </div>
        </div>

        <WorkflowDemo />
      </section>

      <section class="intro-copy reveal-motion" aria-label="Product summary">
        <p>
          DiagramPilot is a local-first, repo-native diagram compiler for AI
          coding agents. It turns local DiagramSpec files into review-stable SVG
          artifacts for software repositories, so diagrams can live in the repo,
          survive code review, and fail with repairable errors.
        </p>
      </section>

      <section class="proof-strip" aria-label="Why DiagramPilot works for agents">
        {proofPoints.map((point) => (
          <article class="proof-item reveal-motion">
            <h2>{point.title}</h2>
            <p>{point.text}</p>
          </article>
        ))}
      </section>

      <LocalRepositoryPath />

      <section class="final-cta reveal-motion" aria-label="DiagramPilot starting points">
        <h2>Starting points.</h2>
        <p>
          Install the CLI, try the checkout demo, inspect the npm package, or
          open the repository before adding DiagramPilot to your agent workflow.
          Public docs cover Output Profiles, DiagramSpec, MCP usage, and
          repairable validation errors.
        </p>
        <div class="hero-actions">
          <a class="action action-primary" href="/docs/agents/installation/">
            Install Guide
          </a>
          <a class="action action-secondary" href="/docs/agents/quickstart/">
            Checkout Demo Project
          </a>
          <a class="action action-secondary" href="/docs/agents/mcp/">
            MCP Guide
          </a>
          <a
            class="action action-secondary"
            href="https://www.npmjs.com/package/diagrampilot"
          >
            npm package
          </a>
          <a class="action action-secondary" href="/docs/">Documentation</a>
          <a
            class="action action-secondary"
            href="https://github.com/StiensWout/DiagramPilot"
          >
            GitHub repository
          </a>
        </div>
      </section>
    </main>
    <script>
      const revealElements = document.querySelectorAll(".reveal-motion");
      const copyButtons = document.querySelectorAll("[data-copy-command]");
      const demoStage = document.querySelector("[data-demo-stage]");
      const demoControls = document.querySelectorAll("[data-demo-control]");
      const demoStatus = document.querySelector("[data-demo-status]");
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const demoMessages = {
        source: "DiagramPilot Source File ready beside the code it explains.",
        check: "Repo workflow check passes without rewriting the working tree.",
        generate: "Derived artifacts are refreshed from the source file.",
        svg: "Review-stable SVG artifact is ready for maintainers.",
      };

      document.body.classList.add("motion-ready");

      if (reduceMotion || !("IntersectionObserver" in window)) {
        revealElements.forEach((element) => element.classList.add("is-visible"));
      } else {
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;

              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          },
          { rootMargin: "0px 0px -12% 0px", threshold: 0.16 },
        );

        revealElements.forEach((element) => observer.observe(element));
      }

      copyButtons.forEach((button) => {
        button.addEventListener("click", async () => {
          const command = button.getAttribute("data-copy-command");

          if (!command || !navigator.clipboard) return;

          await navigator.clipboard.writeText(command);
          button.textContent = "Copied";
          window.setTimeout(() => {
            button.textContent = "Copy";
          }, 1600);
        });
      });

      if (demoStage && demoControls.length > 0) {
        let activeIndex = 0;
        let timer;
        const steps = Array.from(demoControls).map((button) =>
          button.getAttribute("data-demo-control"),
        );

        const setDemoStep = (step, { stopAuto = false } = {}) => {
          if (!step) return;

          activeIndex = Math.max(0, steps.indexOf(step));
          demoStage.setAttribute("data-active-step", step);
          demoControls.forEach((button) => {
            button.setAttribute(
              "aria-pressed",
              button.getAttribute("data-demo-control") === step ? "true" : "false",
            );
          });

          if (demoStatus) {
            demoStatus.textContent = demoMessages[step] ?? "";
          }

          if (stopAuto && timer) {
            window.clearInterval(timer);
            timer = undefined;
          }
        };

        demoControls.forEach((button) => {
          button.addEventListener("click", () => {
            setDemoStep(button.getAttribute("data-demo-control"), { stopAuto: true });
          });
        });

        if (!reduceMotion) {
          timer = window.setInterval(() => {
            activeIndex = (activeIndex + 1) % steps.length;
            setDemoStep(steps[activeIndex]);
          }, 2800);
        }
      }
    </script>
  </body>
</html>
