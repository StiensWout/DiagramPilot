---
const workflowSteps = [
  {
    id: "source",
    label: "Source",
    detail: "docs/architecture.dp.yaml",
    status: "DiagramPilot Source File ready beside the code it explains.",
  },
  {
    id: "check",
    label: "Check",
    detail: "npx diagrampilot check",
    status: "Repo workflow check passes without rewriting the working tree.",
  },
  {
    id: "generate",
    label: "Generate",
    detail: "npx diagrampilot generate",
    status: "Derived artifacts are refreshed from the source file.",
  },
  {
    id: "svg",
    label: "Review",
    detail: "docs/architecture.svg",
    status: "Review-stable SVG artifact is ready for maintainers.",
  },
];
---

<div
  id="workflow-proof"
  class="workflow-proof motion-rise motion-delay-1"
  aria-labelledby="workflow-proof-title"
  aria-label="Interactive DiagramPilot workflow proof"
>
  <div class="workflow-heading">
    <p class="eyebrow">Workflow proof</p>
    <h2 id="workflow-proof-title">
      From `.dp.yaml` to review-stable SVG without leaving the repo.
    </h2>
    <p>
      The same checkout holds source, command output, and the derived artifact
      that goes through code review.
    </p>
  </div>

  <div class="demo-stage" data-demo-stage data-active-step="source">
    <ol class="demo-steps" aria-label="DiagramPilot workflow stages">
      {
        workflowSteps.map((step, index) => (
          <li>
            <button
              type="button"
              class="demo-step"
              data-demo-control={step.id}
              aria-pressed={index === 0 ? "true" : "false"}
            >
              <span class="demo-step-index">
                {String(index + 1).padStart(2, "0")}
              </span>
              <span>
                <strong>{step.label}</strong>
                <code>{step.detail}</code>
              </span>
            </button>
          </li>
        ))
      }
    </ol>

    <p class="demo-status" data-demo-status aria-live="polite">
      {workflowSteps[0].status}
    </p>

    <div
      class="demo-workspace"
      aria-label="DiagramPilot source, terminal output, and SVG artifact"
    >
      <div
        class="demo-pane demo-source"
        data-demo-highlight="source"
        aria-labelledby="demo-source-title"
      >
        <div class="demo-pane-header">
          <span id="demo-source-title">docs/architecture.dp.yaml</span>
          <span>.dp.yaml</span>
        </div>
        <pre><code>version: 1
id: checkout_architecture
title: Checkout service architecture
objects:
  - id: web_app
    label: Web app
    kind: service
  - id: checkout_api
    label: Checkout API
    kind: service
edges:
  - id: submit_order
    from: web_app
    to: checkout_api</code></pre>
      </div>

      <div class="demo-pane demo-terminal" aria-labelledby="demo-terminal-title">
        <div class="demo-pane-header">
          <span id="demo-terminal-title">Terminal</span>
          <span>local checkout</span>
        </div>
        <pre><code><span data-demo-highlight="check">$ npx diagrampilot check
ok 1 DiagramPilot Source File
ok docs/architecture.svg is fresh</span>

<span data-demo-highlight="generate">$ npx diagrampilot generate
ok wrote docs/architecture.svg
ok wrote docs/architecture.md</span></code></pre>
      </div>

      <div
        class="demo-pane demo-output"
        data-demo-highlight="svg"
        aria-labelledby="demo-output-title"
      >
        <div class="demo-pane-header">
          <span id="demo-output-title">Review-stable SVG artifact</span>
          <span>architecture.svg</span>
        </div>
        <svg
          class="demo-svg"
          viewBox="0 0 640 360"
          role="img"
          aria-labelledby="demo-svg-title demo-svg-description"
        >
          <title id="demo-svg-title">Review-stable SVG artifact</title>
          <desc id="demo-svg-description">
            A DiagramPilot architecture SVG showing web, checkout, payment,
            queue, worker, and database components with labeled data flow.
          </desc>
          <defs>
            <marker
              id="artifact-arrow"
              viewBox="0 0 10 10"
              refX="9"
              refY="5"
              markerWidth="7"
              markerHeight="7"
              orient="auto-start-reverse"
            >
              <path class="artifact-arrow-head" d="M0 0L10 5L0 10Z"></path>
            </marker>
          </defs>
          <rect class="artifact-canvas" x="0" y="0" width="640" height="360" rx="12"></rect>
          <g class="artifact-group">
            <rect x="28" y="32" width="584" height="270" rx="14"></rect>
            <text x="52" y="62">demo-projects/checkout</text>
          </g>
          <g class="artifact-node artifact-node-source">
            <rect x="70" y="105" width="132" height="72" rx="10"></rect>
            <text x="136" y="134" text-anchor="middle">web app</text>
            <text x="136" y="156" text-anchor="middle">source checkout</text>
          </g>
          <g class="artifact-node artifact-node-service">
            <rect x="254" y="92" width="132" height="72" rx="10"></rect>
            <text x="320" y="121" text-anchor="middle">checkout API</text>
            <text x="320" y="143" text-anchor="middle">validates order</text>
          </g>
          <g class="artifact-node artifact-node-external">
            <rect x="438" y="105" width="132" height="72" rx="10"></rect>
            <text x="504" y="134" text-anchor="middle">payment provider</text>
            <text x="504" y="156" text-anchor="middle">authorize card</text>
          </g>
          <g class="artifact-node artifact-node-queue">
            <rect x="254" y="214" width="132" height="64" rx="10"></rect>
            <text x="320" y="242" text-anchor="middle">order queue</text>
            <text x="320" y="263" text-anchor="middle">async receipt</text>
          </g>
          <g class="artifact-node artifact-node-data">
            <rect x="70" y="220" width="132" height="58" rx="10"></rect>
            <text x="136" y="245" text-anchor="middle">orders DB</text>
            <text x="136" y="265" text-anchor="middle">persist state</text>
          </g>
          <g class="artifact-node artifact-node-worker">
            <rect x="438" y="220" width="132" height="58" rx="10"></rect>
            <text x="504" y="245" text-anchor="middle">worker</text>
            <text x="504" y="265" text-anchor="middle">send receipt</text>
          </g>
          <path class="artifact-edge artifact-edge-primary" d="M202 141H254"></path>
          <path class="artifact-edge artifact-edge-primary" d="M386 141H438"></path>
          <path class="artifact-edge" d="M320 164V214"></path>
          <path class="artifact-edge" d="M254 246H202"></path>
          <path class="artifact-edge" d="M386 246H438"></path>
          <text class="artifact-label" x="228" y="130" text-anchor="middle">submit</text>
          <text class="artifact-label" x="412" y="130" text-anchor="middle">authorize</text>
          <text class="artifact-label" x="346" y="192" text-anchor="middle">publish</text>
          <text class="artifact-caption" x="320" y="326" text-anchor="middle">
            rendered from docs/architecture.dp.yaml for code review
          </text>
        </svg>
      </div>
    </div>
  </div>
</div>
